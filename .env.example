# ── Database ──────────────────────────────────────────────────
DATABASE_URL=mysql+aiomysql://user:password@localhost:3306/watermark_db

# ── JWT ───────────────────────────────────────────────────────
SECRET_KEY=your-super-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── Vercel Blob ───────────────────────────────────────────────
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxxxxxxxxxxxxx

# ── Partner Watermark API ─────────────────────────────────────
WATERMARK_API_BASE_URL=https://api.watermark.nyanfox.com
WATERMARK_API_TIMEOUT=120

# ── App ───────────────────────────────────────────────────────
APP_ENV=development
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
